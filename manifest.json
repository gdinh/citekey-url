{
  "manifest_version": 2,
  "name": "Citekey URL",
  "version": "1.0",
  "description": "Allows deep linking to Zotero entries by their citekeys",
  "homepage_url": "https://github.com/gdinh/citekey-url",
  "applications": {
    "zotero": {
      "id": "citekey-url@dinh.ai",
      "update_url": "https://raw.githubusercontent.com/gdinh/citeke-url/refs/heads/master/updates.json",
      "strict_min_version": "7.0",
      "strict_max_version": "9.0.*"
    }
  }
}
